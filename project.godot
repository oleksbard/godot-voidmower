config_version=5

; Floating Island Mower — a plain, quick Godot 4 prototype.
; Everything visual is built procedurally in GDScript (see Main.gd), so there
; are no external assets to import. Just open this folder in Godot 4.7 and run.

[application]

config/name="Floating Island Mower"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/stretch/mode="canvas_items"

[rendering]

; Forward+ for the full post-processing stack (ACES tonemap, glow/bloom, SSAO)
; and triplanar normal maps — the techniques the delivery-game look relies on.
renderer/rendering_method="forward_plus"
renderer/rendering_method.mobile="mobile"
; Crisp pixels: each material sets NEAREST filtering itself so procedural
; textures stay sharp regardless of this default.
textures/canvas_textures/default_texture_filter=0
